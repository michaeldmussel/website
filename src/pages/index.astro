---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <section class="pb-12 mt-5">
    <h1 class="text-5xl font-bold">Michael Mussel</h1>
    <div class="text-3xl py-3 font-bold">Software Engineer</div>
    <p class="py-2 text-lg">
      I am working towards my <b> MSc in Computer Science and Engineering </b> at Technische Universiteit Eindhoven, 
      specializing in formal system analysis and intelligent distributed systems. 
      Learning systems design, validation and architecture under leading figures in the field.
      <br></br>
      In <b> Ximius </b> I was tasked with maintaining distributed client data strict errorless and computing restrictions.
      <br></br>
      Sometimes, I create automation tools for niche personal use, system modeling for scale, and program validation.
    </p>
  </section>

  <section>
    <h2 class="text-3xl w-full font-bold mb-2">My recent projects</h2>
  </section>

  <HorizontalCard
    title="Ximius XData - Back-End Hospital Capacity Management"
    img="/XimiusLogo.webp"
    desc="Large data modeling and management work for distributed client data, smart analysis actions, and strict correctness requirements."
    url="/project/ximius-xdata"
    badge="Featured"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Personal RTS clicking automation project"
    img="/post_img.webp"
    desc="Custom software for user simulation experiments simulating mouse actions."
    url="/project/personal-automation-validation"
  />
</BaseLayout>
