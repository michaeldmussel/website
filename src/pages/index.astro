---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <section class="pb-12 mt-5">
    <div class="text-xl py-1">Hello, I am</div>
    <h1 class="text-5xl font-bold">Your Name</h1>
    <div class="text-3xl py-3 font-bold">Your role or professional headline</div>
    <p class="py-2 text-lg">
      Replace this paragraph with a short introduction about who you are, what you do, and what kind of work you want
      visitors to notice first.
    </p>
    <div class="mt-8 flex flex-wrap gap-4">
      <a class="btn" href="/projects">View projects</a>
      <a href="/contact" class="btn btn-outline">Contact me</a>
    </div>
  </section>

  <section>
    <h2 class="text-3xl w-full font-bold mb-2">Featured projects</h2>
    <p class="mb-5 text-base-content/75">
      Add your strongest projects here or edit `src/pages/projects.astro` for the full project list.
    </p>
  </section>

  <HorizontalCard
    title="Project title"
    img="/post_img.webp"
    desc="Replace this with a one-sentence summary of the problem, your role, and the result."
    url="/projects"
    target="_self"
    badge="Featured"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Another project title"
    img="/post_img.webp"
    desc="Replace this with a concise project summary, key technologies, or outcome."
    url="/projects"
    target="_self"
  />
</BaseLayout>
