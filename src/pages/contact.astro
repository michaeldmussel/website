---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" sideBarActiveItemID="contact">
  <section>
    <h1 class="text-3xl w-full font-bold mb-3">Contact</h1>
    <p class="mb-6 text-base-content/75">
      Replace these placeholders with the contact options you want visitors to use.
    </p>

    <div class="grid gap-4">
      <div>
        <div class="font-bold">Email</div>
        <a href="mailto:musselmichael@gmail.com">musselmichael@gmail.com</a>
      </div>
      <div>
        <div class="font-bold">GitHub</div>
        <a href="https://github.com/michaeldmussel" target="_blank">github.com/michaeldmussel</a>
      </div>
      <div>
        <div class="font-bold">LinkedIn</div>
        <a href="https://www.linkedin.com/in/michael-mussel" target="_blank">
          linkedin.com/in/michael-mussel
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
