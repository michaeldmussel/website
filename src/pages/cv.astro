---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
import { withBase } from "../lib/paths";
---

<BaseLayout title="CV" sideBarActiveItemID="cv">
  <section class="mb-10">
    <div class="mb-5">
      <h1 class="text-3xl w-full font-bold">CV</h1>
    </div>
    <p class="mb-5 text-base-content/75">
      MSc Computer Science and Engineering student focused on system validation, data management, and backend software
      development.
    </p>
    <a class="btn btn-outline" href={withBase("/cv.pdf")} download>Download CV PDF</a>
  </section>

  <section class="mb-10">
    <div class="mb-5">
      <h2 class="text-3xl w-full font-bold">Profile</h2>
    </div>
    <p class="text-justify">
      Inquisitive, technically intuitive, and communicative software engineer with a special interest in data management,
      cross-discipline collaboration, and defense technology innovation. I enjoy automating repetitive manual work,
      recreating legacy programs by replacing processing bottlenecks, and understanding how finished technical products
      depend on every part of the engineering process.
    </p>
  </section>

  <section class="mb-10">
    <div class="mb-5">
      <h2 class="text-3xl w-full font-bold">Education</h2>
    </div>
    <div class="time-line-container grid gap-4">
      <TimeLineElement
        title="Master's program of Computer Science and Engineering"
        subtitle="2025 to present, Eindhoven University of Technology, Eindhoven, Netherlands"
      >
        Program verification using BDD graphs, state machine checking, and contract validation. Real-time systems
        schedule construction and validation. Evaluation of existing systems using statistical analysis and design using
        low-latency programming.
      </TimeLineElement>
      <TimeLineElement
        title="Bachelor program of Computer Science and Engineering"
        subtitle="2019 to 2025, Eindhoven University of Technology, Eindhoven, Netherlands"
      >
        Software end project on ExactOnline automation, completed with a final grade of 8.
      </TimeLineElement>
    </div>
  </section>

  <section class="mb-10">
    <div class="mb-5">
      <h2 class="text-3xl w-full font-bold">Experience</h2>
    </div>
    <div class="time-line-container">
      <TimeLineElement
        title="Back-End Software Developer at Ximius"
        subtitle="2022 to 2025"
      >
        Back-end software development for capacity management systems used by diverse international healthcare
        companies. Worked on privacy regulation maintenance, ISO-127001-related requirements, and technical work with
        time-sensitive operations.
      </TimeLineElement>
      <TimeLineElement
        title="Teacher Assistant at Eindhoven University of Technology"
        subtitle="2020 to 2022"
      >
        Supported theoretical exploration and learning beyond individual coursework in the Computer Science and
        Engineering program.
      </TimeLineElement>
    </div>
  </section>

  <section>
    <div class="mb-5">
      <h2 class="text-3xl w-full font-bold">Skills</h2>
    </div>
    <ul class="list-disc md:columns-3 columns-2 mx-6">
      <li>Java</li>
      <li>Python</li>
      <li>Rust</li>
      <li>JavaScript</li>
      <li>HTML</li>
      <li>SQL</li>
      <li>Docker</li>
      <li>Git</li>
      <li>Agile workflow</li>
      <li>Postman</li>
      <li>Microsoft Office</li>
    </ul>
  </section>
</BaseLayout>
