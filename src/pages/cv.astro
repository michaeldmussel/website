---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="CV" sideBarActiveItemID="cv">
  <section class="mb-10">
    <div class="mb-5">
      <h1 class="text-3xl w-full font-bold">CV</h1>
    </div>
    <p class="mb-5 text-base-content/75">
      Replace this page with your real profile, education, experience, certifications, and skills. Put your PDF at
      `public/cv.pdf` so the sidebar download button works.
    </p>
    <a class="btn btn-outline" href="/cv.pdf" download>Download CV PDF</a>
  </section>

  <section class="mb-10">
    <div class="mb-5">
      <h2 class="text-3xl w-full font-bold">Profile</h2>
    </div>
    <p class="text-justify">
      Write a short professional summary here: your current focus, strengths, fields of interest, and the kind of role or
      collaboration you are looking for.
    </p>
  </section>

  <section class="mb-10">
    <div class="mb-5">
      <h2 class="text-3xl w-full font-bold">Education</h2>
    </div>
    <div class="time-line-container grid gap-4">
      <TimeLineElement
        title="Degree or program name"
        subtitle="Start year to end year at institution, city, country"
      />
      <TimeLineElement
        title="Degree, course, or certification"
        subtitle="Start year to end year at institution, city, country"
      />
    </div>
  </section>

  <section class="mb-10">
    <div class="mb-5">
      <h2 class="text-3xl w-full font-bold">Experience</h2>
    </div>
    <div class="time-line-container">
      <TimeLineElement
        title="Role title at company or project"
        subtitle="Start date to end date, city or remote"
      >
        Replace this with the responsibilities, achievements, technologies, and measurable outcomes for this role.
      </TimeLineElement>
      <TimeLineElement
        title="Role title at company or project"
        subtitle="Start date to end date, city or remote"
      >
        Replace this with the responsibilities, achievements, technologies, and measurable outcomes for this role.
      </TimeLineElement>
    </div>
  </section>

  <section class="mb-10">
    <div class="mb-5">
      <h2 class="text-3xl w-full font-bold">Certifications</h2>
    </div>
    <ul class="list-disc mx-6 grid gap-2">
      <li><a href="#" target="_blank">Certification name and issuing organization</a></li>
      <li><a href="#" target="_blank">Certification name and issuing organization</a></li>
    </ul>
  </section>

  <section>
    <div class="mb-5">
      <h2 class="text-3xl w-full font-bold">Skills</h2>
    </div>
    <ul class="list-disc md:columns-3 columns-2 mx-6">
      <li>Skill or technology</li>
      <li>Skill or technology</li>
      <li>Skill or technology</li>
      <li>Skill or technology</li>
      <li>Skill or technology</li>
      <li>Skill or technology</li>
    </ul>
  </section>
</BaseLayout>
