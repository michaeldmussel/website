---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <section>
    <h1 class="text-3xl w-full font-bold mb-3">Projects</h1>
    <p class="mb-6 text-base-content/75">
      These are the two main projects shown on the site. Edit each project page in `src/pages/project/` with the exact
      tools, links, images, and scope you want to present.
    </p>
  </section>

  <HorizontalCard
    title="Ximius XData - Back-End Hospital Capacity Management"
    img="/XimiusLogo.webp"
    desc="Large data modeling and management work for distributed client data, smart analysis actions, and strict correctness requirements."
    url="/project/ximius-xdata"
    badge="Company"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Personal automation and validation project"
    img="/post_img.webp"
    desc="Replace this with your second project: the problem it solves, the tools you used, and the result you want visitors to remember."
    url="/project/personal-automation-validation"
    badge="Personal"
  />
</BaseLayout>
