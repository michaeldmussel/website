---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <section>
    <h1 class="text-3xl w-full font-bold mb-3">Projects</h1>
    <p class="mb-6 text-base-content/75">
      Replace these placeholders with your own projects. Use each card for a project name, image, short description,
      live link, repository link, or case study link.
    </p>
  </section>

  <HorizontalCard
    title="Project name"
    img="/post_img.webp"
    desc="What you built, why it matters, your role, and the main technologies used."
    url="#"
    badge="Add link"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Project name"
    img="/post_img.webp"
    desc="What you built, why it matters, your role, and the main technologies used."
    url="#"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Ximius XData - Back-End Hospital Capacity Management"
    img="/XimiusLogo.webp"
    desc="Large Data modeling and management, while facilitating smart client actions for analysis."
    url="#"
  />
</BaseLayout>
